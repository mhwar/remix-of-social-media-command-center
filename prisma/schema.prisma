// Content Management — Prisma schema
// Database: SQLite (dev). Swap to PostgreSQL in production by changing provider.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------- Enums ----------

enum Role {
  ADMIN
  MANAGER
  MEMBER
}

enum ClientStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  COMPLETED
  ON_HOLD
}

enum TaskStatus {
  IDEA
  WRITING
  REVIEW
  APPROVED
  PUBLISHED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// NOTE: SQLite does not support native enums — Prisma maps these to strings.

// ---------- Models ----------

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("MEMBER")
  tasks     Task[]
  comments  Comment[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id           String      @id @default(cuid())
  nameAr       String
  nameEn       String?
  industry     String?
  description  String?
  website      String?
  contactEmail String?
  contactPhone String?
  logoUrl      String?
  status       String      @default("ACTIVE")
  brandGuide   BrandGuide?
  projects     Project[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model BrandGuide {
  id       String @id @default(cuid())
  clientId String @unique
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // Visual identity
  primaryColor   String?
  secondaryColor String?
  accentColors   String? // JSON string: ["#...","#..."]
  fontArabic     String?
  fontLatin      String?
  logoVariants   String? // JSON string

  // Editorial policy
  toneOfVoice    String?
  brandPersona   String?
  preferredTerms String? // JSON string array
  forbiddenTerms String? // JSON string array
  languages      String? // JSON string array

  // Audience & platforms
  targetAudience  String?
  personas        String? // JSON string
  platforms       String? // JSON string array
  postingSchedule String? // JSON string

  // Media policy
  mediaPolicy     String?
  legalNotes      String?
  hashtagStrategy String?

  // Examples
  sampleContent  String? // JSON array of strings
  referenceLinks String? // JSON array of strings

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id          String    @id @default(cuid())
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      String    @default("PLANNING")
  startDate   DateTime?
  endDate     DateTime?
  tasks       Task[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Task {
  id           String    @id @default(cuid())
  projectId    String
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  status       String    @default("IDEA")
  priority     String    @default("MEDIUM")
  assigneeId   String?
  assignee     User?     @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  dueDate      DateTime?
  publishDate  DateTime?
  platform     String?
  contentType  String?
  contentBody  String?
  aiGenerated  Boolean   @default(false)
  order        Int       @default(0)
  comments     Comment[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())
}
